{
    "name": "apify-ai-sandbox",
    "version": "0.0.1",
    "type": "module",
    "description": "Apify AI Sandbox for running AI coding operations in a containerized environment.",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@types/archiver": "^7.0.0",
        "@types/mime-types": "^3.0.1",
        "apify": "^3.7.0",
        "archiver": "^7.0.1",
        "ejs": "^5.0.1",
        "express": "^5.2.1",
        "http-proxy": "^1.18.1",
        "mime-types": "^3.0.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@apify/eslint-config": "^1.1.0",
        "@apify/tsconfig": "^0.1.1",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.6",
        "@types/http-proxy": "^1.17.17",
        "@types/node": "^25.5.0",
        "eslint": "^9.29.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "scripts": {
        "start": "npm run start:dev",
        "start:local": "MODE=local npm run start:dev",
        "start:prod": "node dist/main.js",
        "start:dev": "tsx src/main.ts",
        "start:standby": "APIFY_META_ORIGIN=\"STANDBY\" npm run start:dev",
        "build": "tsc -p tsconfig.build.json && npm run copy-templates",
        "copy-templates": "mkdir -p dist/templates && cp src/templates/*.ejs src/templates/*.md src/templates/*.ico dist/templates/",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "node --import tsx --test tests/unit/*.test.ts",
        "test:e2e": "tsx tests/e2e.ts"
    },
    "author": "It's not you it's me",
    "license": "ISC"
}
